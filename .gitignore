/gradle-local/
/local.properties
/.idea/
**/build/
/kotlin/

# Local signing cache
debug.keystore

# Firebase
app/src/**/google-services.json
*firebase-adminsdk*.json

# Local secret vault (Kipita artifacts)
/security-vault/
/credentials/

# Dev artifacts & logs
*.log
*.db
window_dump*.xml
latest_logcat*.txt
wallet_runtime.log
replay_pid*.log
hs_err_pid*.log

# One-off migration/fix scripts
fix_*.py
fix_*.js

# Gradle user-home caches (local only)
.gradle-local/
.gradle-user-home/
.gradle-user/
.codex_android/
.kotlin/

# Claude Code session data
.claude/

# iOS / Xcode
ios/**/*.xcconfig
!ios/**/*.xcconfig.template
ios/**/GoogleService-Info.plist
ios/**/.DS_Store
ios/**/DerivedData/
ios/**/*.xcuserstate
ios/**/*.xcworkspace/xcuserdata/

# Web build artifacts
node_modules/
dist/

# Environment files (do NOT commit real secrets)
.env
.env.local
.env.*.local
!.env.example
